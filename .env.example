# Copy to .env for local overrides (never commit real secrets)
# Only VITE_* variables are embedded in the client bundle.

# Provably-fair demo server seed (NEVER use a real production seed in VITE_* vars)
# VITE_DEMO_SERVER_SEED=your-64-char-hex-demo-seed

# Optional authoritative backend (Phase 4) — run `npm run dev:authority` then uncomment:
# VITE_API_BASE=http://127.0.0.1:8787

# CI-only — baked into e2e preview builds by e2e/run-ci.mjs (never set for production deploy)
# VITE_SEED_CUSTODY_BYPASS=ci-e2e

# Authority server (server/devAuthority.mjs) — never use defaults in production
# AUTHORITY_MASTER_SECRET=your-64-char-production-secret
# AUTHORITY_CORS_ORIGIN=https://your-app.example
# AUTHORITY_INSECURE_ALLOW=1

# Feature flags
# VITE_PROVABLY_FAIR_UI=true

# Optional Web Vitals beacon (POST JSON) — e.g. analytics endpoint or dev collector
# VITE_TELEMETRY_URL=https://your-collector.example/vitals
